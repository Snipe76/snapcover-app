# Environment variables needed to run SnapCover
# Copy this file to .env.local and fill in the real values

# ─── Supabase ────────────────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Vercel Cron ────────────────────────────────────────────────────────────
# Random secret — generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret

# ─── Web Push (VAPID) ──────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_EMAIL=mailto:you@example.com
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Exposed to browser — used in lib/notifications.ts to subscribe
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# ─── Email (Resend) ────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key

# ─── App ───────────────────────────────────────────────────────────────────
# Your deployed app URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://snapcover-app.vercel.app
