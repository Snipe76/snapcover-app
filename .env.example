# Environment variables needed to run SnapCover
# Copy this file to .env.local and fill in the real values

# Supabase — get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only (never expose to browser)
# Get the service_role key from the same Supabase API settings page
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Vercel Cron — random secret, generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret

# Web Push (VAPID keys) — generate with: npx web-push generate-vapid-keys
WEB_PUSH_EMAIL=mailto:you@example.com
WEB_PUSH_PUBLIC_KEY=your-vapid-public-key
WEB_PUSH_PRIVATE_KEY=your-vapid-private-key

# Email fallback via Resend — https://resend.com
RESEND_API_KEY=re_your_api_key
