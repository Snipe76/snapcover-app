# See https://help.github.com/articles/ignoring-files/

# ─── Dependencies ────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Testing ─────────────────────────────────────────────────────────────────
/coverage

# ─── Next.js ─────────────────────────────────────────────────────────────────
/.next/
/out/

# ─── Production ───────────────────────────────────────────────────────────────
/build
/dist

# ─── Misc ─────────────────────────────────────────────────────────────────────
.DS_Store
*.pem
*.log
logs/

# ─── Debug ────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Environment & Secrets ─────────────────────────────────────────────────────
# Never commit .env files — real or placeholder
.env
.env.local
.env.*.local
.env.production
# Whitelist the example template (has no real values)
!.env.example

# ─── Credentials & Keys ───────────────────────────────────────────────────────
*.pem
*.key
*.crt
*.p12
*.jks

# ─── Vercel ────────────────────────────────────────────────────────────────────
.vercel
.vercel.output

# ─── Cloudflare ────────────────────────────────────────────────────────────────
.wrangler/

# ─── Turborepo ────────────────────────────────────────────────────────────────
.turbo/

# ─── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── IDE & OS ─────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
Thumbs.db

# ─── OpenClaw (workspace config, not project files) ──────────────────────────
AGENTS.md
CLAUDE.md

# ─── Local Development ─────────────────────────────────────────────────────────
*.local
